{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "python core/manage.py collectstatic --noinput"
  },
  "deploy": {
    "startCommand": "cd core && celery -A core worker -l info --concurrency=1",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}